{
  "objective": "Train a Gemma4 multimodal DiffusionGemma student while maximizing original Gemma4 behavior preservation.",
  "principle": "Use third-party datasets as prompt/context/raw media sources only. Main targets are Gemma4 teacher-generated outputs conditioned on those inputs. Prompt-free self-continuation is not part of the formal pipeline.",
  "formal_target_policy": {
    "teacher_generated_outputs": true,
    "prompt_free_self_continuation": false,
    "third_party_assistant_answers_as_primary_targets": false,
    "raw_corpus_denoising_warmup": "optional"
  },
  "recommended_mix": [
    {
      "bucket": "teacher_supervised_text_prompt_context",
      "share": 0.35,
      "target": "Gemma4 teacher outputs from broad text prompt/context banks"
    },
    {
      "bucket": "teacher_supervised_interleaved_image_text",
      "share": 0.25,
      "target": "Gemma4 teacher outputs from interleaved webpage/PDF/image-text contexts"
    },
    {
      "bucket": "teacher_supervised_image_doc_chart_ocr",
      "share": 0.15,
      "target": "Gemma4 teacher outputs from image QA, OCR, documents, charts, diagrams"
    },
    {
      "bucket": "teacher_supervised_video",
      "share": 0.1,
      "target": "Gemma4 teacher outputs from sampled video/frame contexts"
    },
    {
      "bucket": "teacher_supervised_audio_speech",
      "share": 0.08,
      "target": "Gemma4 teacher outputs from speech/audio contexts"
    },
    {
      "bucket": "teacher_supervised_audio_video",
      "share": 0.05,
      "target": "Gemma4 teacher outputs from synchronized audio-video contexts"
    },
    {
      "bucket": "eval_only",
      "share": 0.02,
      "target": "student-vs-teacher behavior comparison only"
    }
  ],
  "sources": [
